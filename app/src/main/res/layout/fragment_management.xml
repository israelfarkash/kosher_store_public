<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md_theme_light_surface"
    android:orientation="vertical">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="@string/management_title"
            app:titleTextColor="@color/md_theme_light_onSurface" />

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Stats Horizontal Bar -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clipToPadding="false"
        android:overScrollMode="never"
        android:paddingHorizontal="24dp"
        android:paddingVertical="16dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- Installed Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="12dp"
                android:minWidth="140dp"
                app:cardBackgroundColor="@color/md_theme_light_onPrimary"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/md_theme_light_outlineVariant"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/summary_installed"
                        android:textAppearance="?attr/textAppearanceLabelMedium"
                        android:textColor="@color/md_theme_light_onSurfaceVariant" />
                    <TextView
                        android:id="@+id/textInstalledCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textAppearance="?attr/textAppearanceHeadlineSmall"
                        android:textColor="@color/md_theme_light_onSurface"
                        android:textStyle="bold"
                        tools:text="12" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Storage Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="140dp"
                app:cardBackgroundColor="@color/md_theme_light_onPrimary"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/md_theme_light_outlineVariant"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Storage to free"
                        android:textAppearance="?attr/textAppearanceLabelMedium"
                        android:textColor="@color/md_theme_light_onSurfaceVariant" />
                    <TextView
                        android:id="@+id/textFreedSpace"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textAppearance="?attr/textAppearanceHeadlineSmall"
                        android:textColor="@color/md_theme_light_onSurface"
                        android:textStyle="bold"
                        tools:text="256 MB" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </HorizontalScrollView>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/md_theme_light_outlineVariant"
        android:alpha="0.5" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerManagedApps"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="32dp" />

    <TextView
        android:id="@+id/textEmpty"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="48dp"
        android:gravity="center"
        android:paddingHorizontal="48dp"
        android:text="@string/management_empty"
        android:textAppearance="?attr/textAppearanceBodyLarge"
        android:textColor="@color/md_theme_light_onSurfaceVariant"
        android:visibility="gone" />

</LinearLayout>
